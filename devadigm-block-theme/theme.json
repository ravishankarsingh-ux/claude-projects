{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1280px"
		},
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{ "slug": "void", "name": "Void", "color": "#000000" },
				{ "slug": "bone-white", "name": "Bone White", "color": "#ffffff" },
				{ "slug": "ash-gray", "name": "Ash Gray", "color": "#9a9a9a" },
				{ "slug": "silver-mist", "name": "Silver Mist", "color": "#bdbdbd" },
				{ "slug": "electric-iris", "name": "Electric Iris", "color": "#8052ff" },
				{ "slug": "saffron-spark", "name": "Saffron Spark", "color": "#ffb829" },
				{ "slug": "deep-verdant", "name": "Deep Verdant", "color": "#15846e" }
			],
			"gradients": [
				{
					"slug": "iris-verdant",
					"name": "Iris to Verdant",
					"gradient": "linear-gradient(180deg, #8052ff 0%, #15846e 100%)"
				},
				{
					"slug": "portrait-charcoal",
					"name": "Portrait Charcoal",
					"gradient": "linear-gradient(160deg, #1c1c22 0%, #0a0a0d 100%)"
				},
				{
					"slug": "portrait-moss",
					"name": "Portrait Moss",
					"gradient": "linear-gradient(160deg, #1a1e1c 0%, #0a0d0b 100%)"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "inter",
					"name": "Inter",
					"fontFamily": "\"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/inter-latin.woff2" ],
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD"
						},
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/inter-latin-ext.woff2" ],
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF"
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "14px", "fluid": false },
				{ "slug": "body", "name": "Body", "size": "18px", "fluid": false },
				{ "slug": "lead", "name": "Lead", "size": "24px", "fluid": false },
				{
					"slug": "heading-sm",
					"name": "Heading S",
					"size": "42px",
					"fluid": { "min": "32px", "max": "42px" }
				},
				{
					"slug": "heading-lg",
					"name": "Heading L",
					"size": "60px",
					"fluid": { "min": "42px", "max": "60px" }
				},
				{
					"slug": "display",
					"name": "Display",
					"size": "78px",
					"fluid": { "min": "48px", "max": "78px" }
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": [ "px", "em", "rem", "%", "vh", "vw" ],
			"spacingSizes": [
				{ "slug": "6", "name": "1 (6px)", "size": "6px" },
				{ "slug": "12", "name": "2 (12px)", "size": "12px" },
				{ "slug": "18", "name": "3 (18px)", "size": "18px" },
				{ "slug": "24", "name": "4 (24px)", "size": "24px" },
				{ "slug": "30", "name": "5 (30px)", "size": "30px" },
				{ "slug": "36", "name": "6 (36px)", "size": "36px" },
				{ "slug": "60", "name": "7 (60px)", "size": "60px" },
				{ "slug": "96", "name": "8 (96px)", "size": "96px" },
				{ "slug": "120", "name": "9 (120px)", "size": "120px" }
			]
		},
		"custom": {
			"radius": {
				"button": "24px",
				"card": "24px"
			},
			"hairline": "rgba(255, 255, 255, 0.08)"
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|void",
			"text": "var:preset|color|bone-white"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|inter",
			"fontSize": "var:preset|font-size|body",
			"fontWeight": "400",
			"lineHeight": "1.5"
		},
		"spacing": {
			"padding": {
				"left": "var:preset|spacing|36",
				"right": "var:preset|spacing|36"
			},
			"blockGap": "var:preset|spacing|24"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "400",
					"lineHeight": "1.1",
					"letterSpacing": "-0.04em"
				}
			},
			"h1": {
				"typography": { "fontSize": "var:preset|font-size|display" }
			},
			"h2": {
				"typography": { "fontSize": "var:preset|font-size|heading-lg" }
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|heading-sm",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": { "text": "inherit" },
				"typography": { "textDecoration": "none" },
				":hover": {
					"typography": { "textDecoration": "none" }
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|electric-iris",
					"text": "var:preset|color|bone-white"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "600",
					"letterSpacing": "0.025em",
					"textTransform": "uppercase",
					"textDecoration": "none"
				},
				"border": { "radius": "var:custom|radius|button" },
				"spacing": {
					"padding": {
						"top": "14px",
						"bottom": "14px",
						"left": "20px",
						"right": "20px"
					}
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"typography": { "fontWeight": "200" }
			},
			"core/site-title": {
				"typography": {
					"fontSize": "18px",
					"fontWeight": "600",
					"textDecoration": "none"
				},
				"color": { "text": "var:preset|color|bone-white" }
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "400",
					"textTransform": "uppercase",
					"letterSpacing": "0.025em"
				},
				"color": { "text": "var:preset|color|ash-gray" }
			},
			"core/post-title": {
				"typography": {
					"fontWeight": "400",
					"letterSpacing": "-0.04em"
				}
			},
			"core/separator": {
				"color": { "text": "var:custom|hairline" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": []
}
