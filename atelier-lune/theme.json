{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1280px"
		},
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{ "slug": "ink", "name": "Ink", "color": "#14161c" },
				{ "slug": "bone", "name": "Bone", "color": "#ede7dc" },
				{ "slug": "cream", "name": "Cream", "color": "#f7f4ec" },
				{ "slug": "plum", "name": "Plum", "color": "#5b2a3b" },
				{ "slug": "brass", "name": "Brass", "color": "#b08d57" },
				{ "slug": "chalk", "name": "Chalk", "color": "#8c887e" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Fraunces (Display)",
					"fontFamily": "\"Fraunces\", Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontStyle": "normal",
							"fontWeight": "300 600",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/fraunces-latin.woff2" ]
						}
					]
				},
				{
					"slug": "body",
					"name": "Inter (Body)",
					"fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/inter-latin.woff2" ]
						}
					]
				},
				{
					"slug": "mono",
					"name": "IBM Plex Mono",
					"fontFamily": "\"IBM Plex Mono\", ui-monospace, monospace",
					"fontFace": [
						{
							"fontFamily": "IBM Plex Mono",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/plex-mono-400-latin.woff2" ]
						},
						{
							"fontFamily": "IBM Plex Mono",
							"fontStyle": "normal",
							"fontWeight": "500",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/plex-mono-500-latin.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "xs", "name": "XS (mono labels)", "size": "0.72rem", "fluid": false },
				{ "slug": "sm", "name": "Small", "size": "0.94rem", "fluid": false },
				{ "slug": "base", "name": "Base", "size": "1rem", "fluid": false },
				{ "slug": "lede", "name": "Lede", "size": "1.15rem", "fluid": false },
				{ "slug": "md", "name": "Card Heading", "size": "1.2rem", "fluid": false },
				{
					"slug": "quote",
					"name": "Quote",
					"size": "1.6rem",
					"fluid": { "min": "1.3rem", "max": "1.6rem" }
				},
				{
					"slug": "lg",
					"name": "Section Heading",
					"size": "2.6rem",
					"fluid": { "min": "1.9rem", "max": "2.6rem" }
				},
				{
					"slug": "xl",
					"name": "Display",
					"size": "5rem",
					"fluid": { "min": "2.6rem", "max": "5rem" }
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": [ "px", "em", "rem", "%", "vh", "vw" ],
			"spacingSizes": [
				{ "slug": "xs", "name": "XS (0.5rem)", "size": "0.5rem" },
				{ "slug": "sm", "name": "SM (1rem)", "size": "1rem" },
				{ "slug": "md", "name": "MD (2rem)", "size": "2rem" },
				{ "slug": "lg", "name": "LG (4rem)", "size": "4rem" },
				{ "slug": "xl", "name": "XL (7rem)", "size": "7rem" }
			]
		},
		"custom": {
			"line": "rgba(20, 22, 28, 0.14)",
			"lineOnDark": "rgba(237, 231, 220, 0.15)",
			"radius": "2px"
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|bone",
			"text": "var:preset|color|ink"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "16px",
			"fontWeight": "400",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"left": "var:preset|spacing|md",
				"right": "var:preset|spacing|md"
			},
			"blockGap": "var:preset|spacing|sm"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontWeight": "500",
					"letterSpacing": "-0.01em",
					"lineHeight": "1.15"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"lineHeight": "1.02"
				}
			},
			"h2": {
				"typography": { "fontSize": "var:preset|font-size|lg" }
			},
			"h3": {
				"typography": { "fontSize": "var:preset|font-size|md" }
			},
			"link": {
				"color": { "text": "inherit" }
			},
			"button": {
				"color": {
					"background": "var:preset|color|ink",
					"text": "var:preset|color|bone"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontSize": "0.88rem",
					"fontWeight": "500",
					"letterSpacing": "0.02em",
					"textDecoration": "none"
				},
				"border": { "radius": "var:custom|radius" },
				"spacing": {
					"padding": {
						"top": "0.85rem",
						"bottom": "0.85rem",
						"left": "1.6rem",
						"right": "1.6rem"
					}
				},
				":hover": {
					"color": {
						"background": "var:preset|color|plum",
						"text": "var:preset|color|bone"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontSize": "1.15rem",
					"fontWeight": "500",
					"letterSpacing": "0.02em",
					"textDecoration": "none"
				}
			},
			"core/navigation": {
				"typography": { "fontSize": "0.92rem" }
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontSize": "var:preset|font-size|quote",
					"fontWeight": "400",
					"lineHeight": "1.35"
				},
				"border": {
					"left": { "width": "0", "style": "none" }
				},
				"spacing": {
					"padding": { "left": "0" }
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontWeight": "500",
					"letterSpacing": "-0.01em"
				}
			},
			"core/separator": {
				"color": { "text": "var:custom|line" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
